      "@react-native-community/datetimepicker"
    ],

    "experiments": {
      "typedRoutes": true
    },

    "extra": {
      "router": {},
      "eas": {
        "projectId": "d3bc49e0-2548-4c1a-8150-e6db3bc4d090"
      }
    },

    "owner": "veigabruno92s-organization"
  }
