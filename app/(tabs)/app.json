{
  "expo": {
    "name": "TachoMax",
    "slug": "tachomax",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "tachomax",
    "userInterfaceStyle": "dark",

    "ios": {
      "supportsTablet": true
    },

    "android": {
